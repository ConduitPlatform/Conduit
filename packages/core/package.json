    "postbuild": "copyfiles -u 1 src/*.proto ./dist/",
    "prepare": "npm run build",
    "prepublish": "npm run build"
  },
  "license": "ISC",
  "dependencies": {
    "@bufbuild/protobuf": "^2.10.2",
    "@conduitplatform/grpc-sdk": "workspace:*",
