{
  "name": "@conduitplatform/core",
  "version": "1.0.1",
  "main": "dist/bin/www.js",
  "types": "dist/bin/www.d.ts",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node dist/bin/www.js",
    "lint": "eslint src",
    "prebuild": "npm run generateTypes",
    "build": "rimraf dist && tsc",
