    "@conduitplatform/module-tools": "workspace:*",
    "@conduitplatform/node-2fa": "workspace:*",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "bcrypt": "^6.0.0",
    "convict": "^6.2.5",
    "cors": "^2.8.6",
    "deepdash-es": "^5.3.9",
    "fs-extra": "^11.3.4",
    "graphql-tag": "^2.12.6",
    "helmet": "8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/convict": "^6.1.6",
    "@types/cors": "^2.8.19",
    "@types/express": "~5.0.6",
    "@types/is-natural-number": "^4.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "24.9.1",
    "@types/validator": "^13.15.10",
    "copyfiles": "^2.4.1",
    "eslint": "^10.2.0",
    "express": "~5.2.1",
    "globals": "^17.4.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.11.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0"
  }
