{
  "name": "@conduitplatform/communications",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "conduit": {
    "peers": {
      "await": ["database"]
    }
  },
  "scripts": {
    "start": "node dist/index.js",
    "postbuild": "copyfiles -u 1 src/**/*.proto src/*.proto src/**/*.json ./dist/",
    "prebuild": "npm run generateTypes",
    "build": "rimraf dist && tsc",
    "prepare": "npm run build",
    "generateTypes": "sh build.sh",
    "build:docker": "docker build -t ghcr.io/conduitplatform/communications:latest -f ./Dockerfile ../../ && docker push ghcr.io/conduitplatform/communications:latest"
  },
  "directories": {
    "lib": "src"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1073.0",
    "@aws-sdk/client-sns": "^3.1073.0",
    "@bufbuild/protobuf": "^2.12.0",
    "@conduitplatform/grpc-sdk": "workspace:*",
    "@conduitplatform/module-tools": "workspace:*",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@mailchimp/mailchimp_transactional": "^1.4.1",
    "@onesignal/node-onesignal": "^5.9.0",
    "@sendgrid/client": "^8.1.6",
    "await-to-js": "^3.0.0",
    "axios": "^1.18.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.0",
    "convict": "^6.2.5",
    "escape-string-regexp": "^5.0.0",
    "firebase-admin": "^14.0.0",
    "form-data": "^4.0.6",
    "handlebars": "^4.7.9",
    "ioredis": "^5.11.1",
    "lodash-es": "^4.18.1",
    "mailersend": "^3.0.0",
    "mailgun.js": "^13.2.0",
    "messagebird": "^4.0.1",
    "nodemailer": "^9.0.1",
    "nodemailer-mailgun-transport": "^2.1.5",
    "nodemailer-mandrill-transport": "^1.2.0",
    "otp-generator": "^4.0.1",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bluebird": "^3.5.42",
    "@types/convict": "^6.1.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "24.13.2",
    "@types/nodemailer": "^8.0.1",
    "@types/nodemailer-mailgun-transport": "^1.4.6",
    "@types/otp-generator": "^4.0.2",
    "@types/smtp-server": "^3.5.13",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "rimraf": "^6.1.3",
    "smtp-server": "^3.19.1",
    "ts-proto": "^2.11.8",
    "typescript": "~6.0.3"
  }
}
