{
  "name": "@conduitplatform/storage",
  "version": "1.0.1",
  "description": "This will provide a consistent storage mechanism",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "conduit": {
    "peers": {
      "await": ["database"],
      "watch": [
        { "module": "authentication", "edge": "both" },
        { "module": "router", "edge": "rising" }
      ]
    }
  },
  "scripts": {
    "start": "node dist/index.js",
    "prepublish": "npm run build",
    "prebuild": "npm run generateTypes",
    "build": "rimraf dist && tsc",
    "postbuild": "copyfiles -u 1 src/**/*.proto src/*.proto src/**/*.json ./dist/",
    "prepare": "npm run build",
    "build:docker": "docker build -t ghcr.io/conduitplatform/storage:latest -f ./Dockerfile ../../ && docker push ghcr.io/conduitplatform/storage:latest",
    "generateTypes": "sh build.sh"
  },
  "keywords": [],
  "author": "",
  "directories": {
    "lib": "src"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-iam": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/client-sts": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@azure/storage-blob": "^12.32.0",
    "@bufbuild/protobuf": "^2.12.0",
    "@conduitplatform/grpc-sdk": "workspace:*",
    "@conduitplatform/module-tools": "workspace:*",
    "@google-cloud/storage": "^7.21.0",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "ali-oss": "^6.23.0",
    "convict": "^6.2.5",
    "lodash-es": "^4.18.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/convict": "^6.1.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "24.13.2",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.1.3",
    "ts-proto": "^2.12.0",
    "typescript": "~6.0.3"
  }
}
