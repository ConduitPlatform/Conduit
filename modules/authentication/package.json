{
  "name": "@conduitplatform/authentication",
  "version": "1.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "conduit": {
    "peers": {
      "await": ["database"],
      "watch": [
        { "module": "email", "edge": "rising" },
        { "module": "authorization", "edge": "rising" },
        { "module": "sms", "edge": "rising" },
        { "module": "router", "edge": "rising" }
      ]
    }
  },
  "scripts": {
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "prebuild": "npm run generateTypes",
    "build": "rimraf dist && tsc",
    "postbuild": "copyfiles -u 1 src/**/*.proto src/*.proto src/**/*.json ./dist/",
    "build:docker": "docker build -t ghcr.io/conduitplatform/authentication:latest -f ./Dockerfile ../../ && docker push ghcr.io/conduitplatform/authentication:latest",
    "generateTypes": "sh build.sh"
  },
  "license": "ISC",
  "directories": {
    "lib": "src"
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@conduitplatform/grpc-sdk": "workspace:*",
    "@conduitplatform/module-tools": "workspace:*",
    "@conduitplatform/node-2fa": "workspace:*",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "axios": "^1.18.0",
    "bcrypt": "^6.0.0",
    "convict": "^6.2.5",
    "escape-string-regexp": "^5.0.0",
    "@ethereumjs/util": "^10.1.2",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.1.0",
    "lodash-es": "^4.18.1",
    "moment": "^2.30.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/convict": "^6.1.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "24.13.2",
    "copyfiles": "^2.4.1",
    "rimraf": "^6.1.3",
    "ts-proto": "^2.11.9",
    "typescript": "~6.0.3"
  }
}
